# Echelon Analytics — Environment Configuration
# Copy to .env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────────────

# Port the app listens on (default: 1947)
ECHELON_PORT=1947

# SQLite database path (default: ./echelon.db)
ECHELON_DB_PATH=/app/data/echelon.db

# API bearer token — required for /api/* endpoints and admin access
# Generate: openssl rand -hex 32
ECHELON_SECRET=

# ── Auth ─────────────────────────────────────────────────────────────────────

# Admin login credentials
# Username for the admin panel — change this from the default
ECHELON_USERNAME=

# PBKDF2 hash of the admin password
# Generate: deno eval "import{hashPassword}from'./echelon-analytics/lib/auth.ts';console.log(await hashPassword('yourpassword'))"
ECHELON_PASSWORD_HASH=

# ── Rate Limiting ────────────────────────────────────────────────────────────

# Max requests per IP per window on tracking endpoints (default: 100)
# Set to 0 to disable rate limiting.
# ECHELON_RATE_LIMIT_MAX=100

# Rate limit window in ms (default: 60000 = 1 min)
# ECHELON_RATE_LIMIT_WINDOW_MS=60000

# ── Buffered Writers ─────────────────────────────────────────────────────────

# How often to flush buffered pageviews to SQLite, in ms (default: 120000 = 2 min)
# ECHELON_VIEW_FLUSH_MS=120000

# How often to flush buffered events to SQLite, in ms (default: 10000 = 10s)
# ECHELON_EVENT_FLUSH_MS=10000

# ── Allowed Origins ──────────────────────────────────────────────────────────

# Comma-separated list of domains allowed to send tracking data.
# When set, only these domains can load ea.js, send beacons, and post events.
# Empty = accept all origins (open mode).
# Example: islets.app,www.islets.app,afroute.com,zambia.afroute.com,maroc.afroute.com
ECHELON_ALLOWED_ORIGINS=

# ── Data Retention ───────────────────────────────────────────────────────────

# Days to keep raw visitor_views and semantic_events (default: 90)
# Daily rollups are kept for 2 years regardless of this setting.
ECHELON_RETENTION_DAYS=90

# ── Bot Detection ────────────────────────────────────────────────────────────

# Comma-separated ISO country codes considered suspicious globally (default: CN)
ECHELON_SUSPECT_COUNTRIES=CN

# Bot score points added for suspect country visitors (default: 30)
ECHELON_SUSPECT_POINTS=30

# Per-site suspect country overrides — format: "site_id:CC,CC;site_id:CC"
# These add SUSPECT_POINTS on top of the global SUSPECT_COUNTRIES list.
# Example: maroc.afroute.com:CN,RU;zambia.afroute.com:CN
# ECHELON_SITE_SUSPECT_COUNTRIES=

# Bot score threshold for discarding traffic entirely (default: 0 = keep all).
# Views/events with bot_score >= this value are dropped and never stored.
# Set to 50 to drop likely bots. Rollups always filter bot_score < 50 regardless.
# ECHELON_BOT_DISCARD_THRESHOLD=50

# Known bot UA substrings (comma-separated, case-insensitive).
# Requests matching any pattern are silently dropped (not tracked at all).
# Defaults include Googlebot, Bingbot, GPTBot, ClaudeBot, Applebot, etc.
# Set to override the entire list. Empty string disables UA-based blocking.
# ECHELON_BOT_UA_PATTERNS=Googlebot,Bingbot,GPTBot,ClaudeBot,...

# ── Deployment ───────────────────────────────────────────────────────────────

# Bind address for Docker port mapping (default: 127.0.0.1)
BIND_ADDRESS=127.0.0.1

# Comma-separated IPs allowed through firewall (optional)
# ALLOWED_IPS=1.2.3.4,5.6.7.8

# CPU cores to allocate to the Docker container (default: 1)
CPU_CORES=1

# Docker network to join (optional, for Postgres connectivity)
# DOCKER_NETWORK=mynet
